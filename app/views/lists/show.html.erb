<div class="lists p-4">
  <h2 class="mb-4">Liste : <%= @list.name %></h2>
  <div class="row">
    <div class="col-8">
      <% if @list.movies.empty? %>
        <p>Vous n'avez aucun film dans cette liste. Commencez !</p>
      <% end %>
      <ul class="list-unstyled m-0 p-0 gap-4">
        <% @list.bookmarks.reverse.each do |bookmark| %>
          <li>
            <div class="card rounded-4 overflow-hidden">
              <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="Poster of <%= bookmark.movie.title %>">
              <div class="card-body">
                <h6><%= bookmark.movie.title %></h6>
                <p class="card-overview text-secondary"><%= truncate(bookmark.movie.overview, length: 100) %></p>
                <div class="text-info d-flex align-items-center gap-2">
                  <i class="fa-solid fa-star"></i>
                  <span><%= bookmark.movie.rating %></span>
                </div>
                <div class="d-flex mt-3 align-items-center justify-content-between">
                  <cite class="card-citation"><%= bookmark.comment %></cite>
                  <%= link_to bookmark_path(bookmark), data: {turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?"}, class: "btn btn-outline-info btn-trash rounded-pill py-1 px-2" do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
    <div class="col-4">
      <div class="rounded-4 bg-black p-4">
        <h5 class="mb-4">Ajouter un film</h5>
        <%= render "bookmarks/form", list: @list, bookmark: @bookmark %>
      </div>
    </div>
  </div>

  <div class="border-top mt-5 py-4">
    <%= link_to "Mes listes", lists_path, class: "btn btn-outline-info rounded-pill" %>
  </div>
</div>
